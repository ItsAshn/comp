# Path to the SQLite file. Local dev uses a repo-relative file; the container
# overrides this to the bind-mounted volume at /data/comp.db.
DATABASE_PATH=./data/comp.db

# --- Deployment only (read by docker-compose.yml, not by the app) ------------

# The app's fixed address on the external `cloudflareTunnel` network, so the
# tunnel's ingress rule has a stable target. Must sit inside that network's
# subnet and not already be taken — Docker assigns dynamic addresses from the
# same range, so pick a high host number. Check the subnet and what's on it:
#   docker network inspect cloudflareTunnel
APP_IP=172.18.0.20

# "Today" is decided server-side, so a host left on UTC can file an evening
# weigh-in under tomorrow. Only needed where the system clock isn't your zone
# (the container defaults to Etc/UTC).
# TZ=Europe/London
