# Path to the SQLite file. Local dev uses a repo-relative file; the container
# overrides this to the bind-mounted volume at /data/comp.db.
DATABASE_PATH=./data/comp.db

# "Today" is decided server-side, so a host left on UTC can file an evening
# weigh-in under tomorrow. Only needed where the system clock isn't your zone
# (the container defaults to Etc/UTC).
# TZ=Europe/London
